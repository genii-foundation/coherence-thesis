{
  "name": "coherence-thesis",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "bootstrap": "node scripts/ensure-node-modules.mjs",
    "predev": "npm run manuscripts:prepare",
    "dev": "next dev",
    "preview:dev": "node scripts/dev-preview.mjs start",
    "preview:dev:status": "node scripts/dev-preview.mjs status",
    "preview:dev:stop": "node scripts/dev-preview.mjs stop",
    "predev:e2e": "npm run manuscripts:prepare",
    "dev:e2e": "NEXT_E2E_FAST=1 next dev --hostname 127.0.0.1 --port 3200",
    "prebuild": "npm run manuscripts:prepare",
    "build": "npm run updates:generate && next build",
    "prestart": "npm run manuscripts:prepare",
    "start": "next start --hostname 127.0.0.1 --port 3100",
    "prepreview:production": "npm run manuscripts:prepare",
    "preview:production": "next start --hostname 127.0.0.1 --port 3100",
    "prelint": "npm run manuscripts:prepare",
    "lint": "eslint",
    "pretypecheck": "npm run manuscripts:prepare",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run manuscripts:prepare",
    "test": "vitest run",
    "pretest:coverage": "npm run manuscripts:prepare",
    "test:coverage": "vitest run --coverage",
    "pretest:e2e": "npm run manuscripts:prepare",
    "test:e2e": "playwright test",
    "pretest:e2e:fast": "npm run manuscripts:prepare",
    "test:e2e:fast": "PLAYWRIGHT_FAST=1 playwright test",
    "pretest:e2e:fast:desktop": "npm run manuscripts:prepare",
    "test:e2e:fast:desktop": "PLAYWRIGHT_FAST=1 playwright test --project=desktop",
    "premanuscripts:import": "node scripts/ensure-node-modules.mjs",
    "manuscripts:import": "tsx scripts/manuscripts/import-markdown.ts",
    "premanuscripts:compile": "node scripts/ensure-node-modules.mjs",
    "manuscripts:compile": "tsx scripts/manuscripts/compile.ts",
    "premanuscripts:prepare": "node scripts/ensure-node-modules.mjs",
    "manuscripts:prepare": "tsx scripts/manuscripts/prepare.ts",
    "premanuscripts:record-routes": "npm run manuscripts:prepare",
    "manuscripts:record-routes": "tsx scripts/manuscripts/record-routes.ts",
    "premanuscripts:versions": "npm run manuscripts:prepare",
    "manuscripts:versions": "tsx scripts/manuscripts/versions.ts",
    "premanuscripts:validate": "npm run manuscripts:prepare",
    "manuscripts:validate": "tsx scripts/manuscripts/validate.ts",
    "premanuscripts:debt": "node scripts/ensure-node-modules.mjs",
    "manuscripts:debt": "tsx scripts/manuscripts/editorial-debt.ts",
    "premanuscripts:debt:update": "node scripts/ensure-node-modules.mjs",
    "manuscripts:debt:update": "tsx scripts/manuscripts/editorial-debt.ts --write",
    "preupdates:generate": "node scripts/ensure-node-modules.mjs",
    "updates:generate": "tsx scripts/updates/generate.ts",
    "updates:verify": "tsx scripts/updates/verify.ts",
    "premanuscripts:source-boundary": "node scripts/ensure-node-modules.mjs",
    "manuscripts:source-boundary": "tsx scripts/manuscripts/source-boundary.ts",
    "preaudio:fish": "npm run manuscripts:prepare",
    "audio:fish": "tsx scripts/audio/fish-generate.ts",
    "preaudio:publish-manifest": "npm run manuscripts:prepare",
    "audio:publish-manifest": "tsx scripts/audio/fish-publish-manifest.ts",
    "prereadme:update": "npm run manuscripts:prepare",
    "readme:update": "tsx scripts/update-readme-status.ts",
    "prevalidate": "npm run manuscripts:prepare",
    "validate": "npm run manuscripts:debt && npm run manuscripts:validate && npm run manuscripts:source-boundary && npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.9"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "pdfkit": "^0.19.1",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
