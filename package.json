{
  "name": "coherence-thesis",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "bootstrap": "node scripts/ensure-node-modules.mjs",
    "predev": "node scripts/ensure-node-modules.mjs",
    "dev": "next dev",
    "preview:dev": "node scripts/dev-preview.mjs start",
    "preview:dev:status": "node scripts/dev-preview.mjs status",
    "preview:dev:stop": "node scripts/dev-preview.mjs stop",
    "predev:e2e": "node scripts/ensure-node-modules.mjs",
    "dev:e2e": "NEXT_E2E_FAST=1 next dev --hostname 127.0.0.1 --port 3200",
    "prebuild": "node scripts/ensure-node-modules.mjs",
    "build": "npm run manuscripts:compile && next build",
    "prestart": "node scripts/ensure-node-modules.mjs",
    "start": "next start --hostname 127.0.0.1 --port 3100",
    "prepreview:production": "node scripts/ensure-node-modules.mjs",
    "preview:production": "next start --hostname 127.0.0.1 --port 3100",
    "prelint": "node scripts/ensure-node-modules.mjs",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/ensure-node-modules.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "pretest:e2e": "node scripts/ensure-node-modules.mjs",
    "test:e2e": "playwright test",
    "pretest:e2e:fast": "node scripts/ensure-node-modules.mjs",
    "test:e2e:fast": "PLAYWRIGHT_FAST=1 playwright test",
    "pretest:e2e:fast:desktop": "node scripts/ensure-node-modules.mjs",
    "test:e2e:fast:desktop": "PLAYWRIGHT_FAST=1 playwright test --project=desktop",
    "premanuscripts:import": "node scripts/ensure-node-modules.mjs",
    "manuscripts:import": "node --import tsx scripts/manuscripts/import-markdown.ts",
    "premanuscripts:compile": "node scripts/ensure-node-modules.mjs",
    "manuscripts:compile": "node --import tsx scripts/manuscripts/compile.ts",
    "premanuscripts:versions": "node scripts/ensure-node-modules.mjs",
    "manuscripts:versions": "node --import tsx scripts/manuscripts/versions.ts",
    "premanuscripts:validate": "node scripts/ensure-node-modules.mjs",
    "manuscripts:validate": "node --import tsx scripts/manuscripts/validate.ts",
    "premanuscripts:editorial": "node scripts/ensure-node-modules.mjs",
    "manuscripts:editorial": "node --import tsx scripts/manuscripts/editorial-lint.ts",
    "premanuscripts:debt": "node scripts/ensure-node-modules.mjs",
    "manuscripts:debt": "node --import tsx scripts/manuscripts/editorial-debt.ts",
    "premanuscripts:debt:update": "node scripts/ensure-node-modules.mjs",
    "manuscripts:debt:update": "node --import tsx scripts/manuscripts/editorial-debt.ts --write",
    "premanuscripts:editorial-ledger": "node scripts/ensure-node-modules.mjs",
    "manuscripts:editorial-ledger": "node --import tsx scripts/manuscripts/editorial-ledger.ts",
    "premanuscripts:editorial-ledgers:init": "node scripts/ensure-node-modules.mjs",
    "manuscripts:editorial-ledgers:init": "node --import tsx scripts/manuscripts/editorial-ledger-init.ts",
    "premanuscripts:structure-ledger": "node scripts/ensure-node-modules.mjs",
    "manuscripts:structure-ledger": "node --import tsx scripts/manuscripts/editorial-structure-ledger.ts",
    "premanuscripts:preserve-links": "node scripts/ensure-node-modules.mjs",
    "manuscripts:preserve-links": "node --import tsx scripts/manuscripts/preserve-links.ts",
    "premanuscripts:audit-history": "node scripts/ensure-node-modules.mjs",
    "manuscripts:audit-history": "node --import tsx scripts/manuscripts/audit-historical-links.ts",
    "premanuscripts:editorial:strict": "node scripts/ensure-node-modules.mjs",
    "manuscripts:editorial:strict": "node --import tsx scripts/manuscripts/editorial-lint.ts --strict",
    "audio:fish": "node --import tsx scripts/audio/fish-generate.ts",
    "audio:publish-manifest": "node --import tsx scripts/audio/fish-publish-manifest.ts",
    "prereadme:update": "node scripts/ensure-node-modules.mjs",
    "readme:update": "node --import tsx scripts/update-readme-status.ts",
    "prevalidate": "node scripts/ensure-node-modules.mjs",
    "validate": "npm run manuscripts:debt && npm run manuscripts:validate && npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.9"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "pdfkit": "^0.19.1",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
